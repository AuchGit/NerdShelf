{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NerdShelf",
  "version": "0.1.14",
  "identifier": "io.github.auchgit.nerdshelf",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5283",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AuchGit/NerdShelf/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1NDRGRDhCNTM0NjAyODUKUldTRkFrWlRpLzFFbFJVK2diRmU5WWxGeXJ1THgzTndhSER5dEJDMERZd0hNSnBTd1p5QVpLcEsK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "NerdShelf",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
